{
  "compileOnSave": false,
    "compilerOptions": {
      "target": "es5",
      "module": "none",
      "lib": ["ES5", "DOM"],
      "skipLibCheck": true,
      "sourceMap": false,
      "incremental": true,
      "moduleResolution": "node",
      "noImplicitAny": true,
      "removeComments": true,
      "preserveConstEnums": false,
      "downlevelIteration": true,
      "watch": false
    },
    "exclude": [
      "node_modules",
      "./node_modules",
      "./node_modules/*",
      "js",
      "admin",
      "mocha_tests",
      "docs",
      "test",
      "typescript_js",
      "dist",
      "release",
      "debug",
      "welcome"
    ]
  }
